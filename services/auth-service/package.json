{
  "name": "@crowdflow/auth-service",
  "version": "1.0.0",
  "private": true,
  "description": "CrowdFlow Authentication Service — JWT + Firebase Auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "mercurius": "^15.0.0",
    "graphql": "^16.9.0",
    "argon2": "^0.41.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.0",
    "zod": "^3.23.0",
    "firebase-admin": "^13.0.0",
    "pino": "^9.5.0",
    "fastify-plugin": "^5.0.0",
    "@crowdflow/shared-types": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "pino-pretty": "^13.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.0"
  }
}
