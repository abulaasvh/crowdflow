{
  "name": "@crowdflow/crowd-service",
  "version": "1.0.0",
  "private": true,
  "description": "CrowdFlow Crowd Intelligence Service — Real-time heatmap and density",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "socket.io": "^4.8.0",
    "ioredis": "^5.4.0",
    "uuid": "^11.0.0",
    "pino": "^9.5.0",
    "@crowdflow/shared-types": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "pino-pretty": "^13.0.0",
    "@types/uuid": "^10.0.0",
    "rimraf": "^6.0.0"
  }
}
