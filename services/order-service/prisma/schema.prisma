generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String   // e.g., 'FOOD', 'DRINK', 'MERCH'
  imageUrl    String?
  isAvailable Boolean  @default(true)
  orderItems  OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  userId          String      // Link to auth-service User ID
  orderNumber     String      @unique // e.g., #CF-1001
  status          String      @default("PENDING") // PENDING, CONFIRMED, PREPARING, READY, COMPLETED, CANCELLED
  totalPrice      Decimal     @db.Decimal(10, 2)
  seatInfo        String?     // e.g., 'Section A, Row 12, Seat 5'
  stripePaymentId String?     @unique
  items           OrderItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
}
