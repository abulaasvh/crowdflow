# ──────────────────────────────────────
# CrowdFlow Environment Configuration
# ──────────────────────────────────────

# General
NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://crowdflow:crowdflow_secret@localhost:5432/crowdflow?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Firebase (Google Services)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Crowd Service
CROWD_SERVICE_PORT=4001
WEBSOCKET_PORT=4002

# Notification Service
NOTIFICATION_SERVICE_PORT=4003

# Order Service
ORDER_SERVICE_PORT=4004

# Staff Dashboard
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4002
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
